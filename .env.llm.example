# Proveedor LLM para recomendaciones (openai | openrouter | custom)
RECOMMENDATION_LLM_PROVIDER=openai

# Clave del proveedor
RECOMMENDATION_LLM_API_KEY=

# Modelo a usar
RECOMMENDATION_LLM_MODEL=gpt-4o-mini

# Timeout de llamada al LLM en milisegundos
RECOMMENDATION_LLM_TIMEOUT_MS=12000

# Chat de Zoe (si no se configura premium, usa el motor local anterior)
ZOE_CHAT_TIMEOUT_MS=7000

# Ruta premium opcional (se intenta primero y si falla cae al motor local)
ZOE_PREMIUM_LLM_URL=
ZOE_PREMIUM_LLM_API_KEY=
ZOE_PREMIUM_LLM_MODEL=
ZOE_PREMIUM_CHAT_TIMEOUT_MS=9000

# Configuracion de alertas en vista principal (milisegundos)
MAIN_ALERT_WINDOW_MS=900000
OVERLAY_WARNING_TTL_MS=25000
OVERLAY_INFO_TTL_MS=12000

# Opcional: URL custom de chat completions.
# Si se deja vacio y provider=openai/openrouter, se usa URL por defecto.
RECOMMENDATION_LLM_URL=

# Solo para OpenRouter (opcionales)
RECOMMENDATION_LLM_APP_URL=http://localhost
RECOMMENDATION_LLM_APP_NAME=medical-agent
