# Configuracion de Ollama local para recomendaciones IA
# Ollama proporciona una API compatible con OpenAI sin necesidad de API key

RECOMMENDATION_LLM_PROVIDER=custom
RECOMMENDATION_LLM_URL=http://localhost:11434/v1/chat/completions
RECOMMENDATION_LLM_API_KEY=
RECOMMENDATION_LLM_MODEL=qwen2.5:7b-instruct
RECOMMENDATION_LLM_TIMEOUT_MS=20000
ZOE_CHAT_TIMEOUT_MS=7000
LLM_DECISION_TIMEOUT_MS=32000
LLM_RECOMMENDATION_TIMEOUT_MS=22000

# Ruta premium opcional para Zoe (si se configura, se intenta primero)
# Ejemplo OpenAI compatible:
# ZOE_PREMIUM_LLM_URL=https://api.openai.com/v1/chat/completions
# ZOE_PREMIUM_LLM_API_KEY=sk-...
# ZOE_PREMIUM_LLM_MODEL=gpt-5.3-codex
# ZOE_PREMIUM_CHAT_TIMEOUT_MS=9000

# Configuracion de alertas en vista principal (milisegundos)
MAIN_ALERT_WINDOW_MS=60000
OVERLAY_WARNING_TTL_MS=12000
OVERLAY_INFO_TTL_MS=8000

# Configuracion de voz TTS servidor (audio backend)
# Cambia estos valores para ajustar timbre/velocidad sin tocar codigo.
TTS_ENGINE=piper
TTS_ESPEAK_VOICE=es-la+f2
TTS_ESPEAK_SPEED=122
TTS_ESPEAK_PITCH=20

# Piper (voz mucho más natural que espeak-ng)
# Ejemplo de modelo: /home/walgeo/voices/es_MX-claude-high.onnx
# Si no defines TTS_PIPER_MODEL/TTS_PIPER_BIN, el backend usa el bundle en vendor/tts.
# Dejar vacios para usar el bundle automatico del proyecto (portable entre maquinas).
TTS_BUNDLED_DIR=
TTS_BUNDLED_MODEL=
TTS_PIPER_MODEL=./vendor/tts/models/es_MX-claude-high.onnx
TTS_PIPER_BIN=./vendor/tts/piper/piper/piper
TTS_PIPER_LENGTH_SCALE=1.05
TTS_PIPER_NOISE_SCALE=0.4
TTS_PIPER_NOISE_W=0.75
